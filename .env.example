# App
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/wakeup.db

# Anthropic Claude — required for perception, planning, outreach
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Resend (SDK: resend.Emails.send) — replace re_xxxxxxxxx with your real API key ---
#
# SANDBOX (keep building without a verified domain):
#   • Outbound always uses Resend (`RESEND_API_KEY` required).
#   • EMAIL_FROM must stay on onboarding@resend.dev (Resend’s sandbox “from”)
#   • In the Resend dashboard, add your personal email under test / allowed recipients
#     so outreach "prospect_email" can be that address (see Resend “send test emails” docs).
# PRODUCTION (later): verify your domain, then EMAIL_FROM=Name <you@yourdomain.com>
#
RESEND_API_KEY=re_xxxxxxxxx
# Key must allow Receiving APIs (not “send only”) — inbound webhooks call Emails Receiving.retrieve
EMAIL_FROM=Wakeup Agent <onboarding@resend.dev>
# Receiving route (anything@<team>.resend.app).
EMAIL_REPLY_TO=wakeup-agent@yourteam.resend.app
# true = also Cc EMAIL_REPLY_TO (needs verified sending domain — breaks onboarding@resend.dev + extra recipients)
EMAIL_MIRROR_REPLY_TO_IN_CC=false
EMAIL_CC=
EMAIL_REPLY_DOMAIN=example.com

# Optional: comma-separated Gmail(s) allowed as prospect — blocks outreach + all outbound otherwise
SANDBOX_ALLOWED_TO_EMAILS=gptprince4274@gmail.com

# Inbound webhook — set a secret to verify signatures if your provider supports it
WEBHOOK_SECRET=

# Stub calendar — booking is deterministic slot selection unless you integrate Cal.com/Google
CALENDAR_MODE=stub
STUB_AVAILABLE_SLOTS_ISO=2026-05-12T14:00:00+00:00,2026-05-13T16:30:00+00:00,2026-05-14T10:00:00+00:00

# Default gig preset (IDs match app/config presets)
DEFAULT_AGENT_PRESET=default_demo
