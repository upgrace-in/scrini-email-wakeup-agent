# App
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/wakeup.db

# OpenAI — required for perception + planning
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Outbound email (Resend) — omit to use MOCK_EMAIL=true for local/demo
MOCK_EMAIL=true
RESEND_API_KEY=re_...
EMAIL_FROM=Wakeup Agent <agent@updates.yourdomain.com>
EMAIL_REPLY_DOMAIN=updates.yourdomain.com

# Inbound webhook — set a secret to verify signatures if your provider supports it
WEBHOOK_SECRET=

# Stub calendar — booking is deterministic slot selection unless you integrate Cal.com/Google
CALENDAR_MODE=stub
STUB_AVAILABLE_SLOTS_ISO=2026-05-12T14:00:00+00:00,2026-05-13T16:30:00+00:00,2026-05-14T10:00:00+00:00

# Default gig preset (IDs match app/config presets)
DEFAULT_AGENT_PRESET=default_demo
